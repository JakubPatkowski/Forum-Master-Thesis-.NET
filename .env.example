# Copy to .env and adjust. Read by scripts/*.sh, the Makefile AND docker compose
# (compose interpolates ${VAR}). .env is gitignored — never commit real secrets.

# --- Local infra (docker compose) -------------------------------------------
POSTGRES_DB=forum_net
POSTGRES_USER=forum
POSTGRES_PASSWORD=forum_dev_only
# MinIO — defaults below match scripts/lib.sh; override here only if you need different values.
# MINIO_BUCKET must match the app's Storage:Bucket setting (appsettings.json default: "forum").
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_only
MINIO_BUCKET=forum

# --- minikube / kubernetes --------------------------------------------------
MINIKUBE_PROFILE=forum
# Phase 10b resource contract (§1 of the enterprise plan): 6 vCPU / 10 GiB minikube VM.
# 10240 requires .wslconfig memory=12GB ('wsl --shutdown' after changing it) — preflight checks.
# The app stack alone (no 10c monitoring) also runs in MINIKUBE_MEMORY=8192.
MINIKUBE_CPUS=6
MINIKUBE_MEMORY=10240
MINIKUBE_DRIVER=docker
K8S_NAMESPACE=forum-dotnet
IMAGE_NAME=forum-dotnet-api
IMAGE_NAME_WEB=forum-dotnet-web
# IMAGE_TAG defaults to git-<short-sha> of HEAD ("-dirty" appended on uncommitted changes)
# so every image maps to an exact build. Uncomment to pin the old fixed tag instead:
# IMAGE_TAG=local
# Frontend image build-time API origin — scheme://host[:port], NEVER with a /api path
# (call sites already prefix /api/..., a path here 404s everything as /api/api/...).
# Defaults to https://$INGRESS_HOST (the cluster ingress terminates TLS since Phase 10b);
# override e.g. for a local smoke test:
# NEXT_PUBLIC_API_URL=http://localhost:8080
INGRESS_HOST=forum.local

# Cluster-only credentials (Phase 10b). deploy.sh creates the k8s secrets generate-if-missing:
# leave these empty/unset to get random generated values on first deploy (already-created
# in-cluster secrets are never overwritten). Set them only if you want fixed values.
# RABBITMQ_USER=forum
# RABBITMQ_PASSWORD=
# JWT_SIGNING_KEY=

# NetworkPolicies are enforced (calico) with explicit allow-rules since Phase 10b — default true.
# false is an escape hatch for debugging only; admin access never needs it (kubectl port-forward
# bypasses netpol via the API server by design).
APPLY_NETWORK_POLICIES=true
