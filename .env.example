# Copy to .env and adjust. Read by scripts/*.sh, the Makefile AND docker compose
# (compose interpolates ${VAR}). .env is gitignored — never commit real secrets.

# --- Local infra (docker compose) -------------------------------------------
POSTGRES_DB=forum_net
POSTGRES_USER=forum
POSTGRES_PASSWORD=forum_dev_only
# MinIO (only needed if you want infra-up.sh to auto-create a bucket)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_only
# MINIO_BUCKET=forum-files

# --- minikube / kubernetes --------------------------------------------------
MINIKUBE_PROFILE=forum
MINIKUBE_CPUS=4
MINIKUBE_MEMORY=8192
MINIKUBE_DRIVER=docker
K8S_NAMESPACE=forum-dotnet
IMAGE_NAME=forum-dotnet-api
IMAGE_TAG=local
INGRESS_HOST=forum.local

# Leave false until companion allow-rules exist for default-deny-ingress,
# otherwise NetworkPolicies block ingress->backend and backend->postgres.
APPLY_NETWORK_POLICIES=false
