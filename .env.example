# Copy to .env and adjust. Read by scripts/*.sh, the Makefile AND docker compose
# (compose interpolates ${VAR}). .env is gitignored — never commit real secrets.

# --- Local infra (docker compose) -------------------------------------------
POSTGRES_DB=forum_net
POSTGRES_USER=forum
POSTGRES_PASSWORD=forum_dev_only
# MinIO — defaults below match scripts/lib.sh; override here only if you need different values.
# MINIO_BUCKET must match the app's Storage:Bucket setting (appsettings.json default: "forum").
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_only
MINIO_BUCKET=forum

# --- minikube / kubernetes --------------------------------------------------
MINIKUBE_PROFILE=forum
MINIKUBE_CPUS=4
MINIKUBE_MEMORY=8192
MINIKUBE_DRIVER=docker
K8S_NAMESPACE=forum-dotnet
IMAGE_NAME=forum-dotnet-api
IMAGE_NAME_WEB=forum-dotnet-web
# IMAGE_TAG defaults to git-<short-sha> of HEAD ("-dirty" appended on uncommitted changes)
# so every image maps to an exact build. Uncomment to pin the old fixed tag instead:
# IMAGE_TAG=local
# Frontend image build-time API origin — scheme://host[:port], NEVER with a /api path
# (call sites already prefix /api/..., a path here 404s everything as /api/api/...).
# Defaults to http://$INGRESS_HOST; override e.g. for a local smoke test:
# NEXT_PUBLIC_API_URL=http://localhost:8080
INGRESS_HOST=forum.local

# Leave false until companion allow-rules exist for default-deny-ingress,
# otherwise NetworkPolicies block ingress->backend and backend->postgres.
APPLY_NETWORK_POLICIES=false
