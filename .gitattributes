# Normalize line endings: LF in the repo, auto on checkout per-OS.
* text=auto eol=lf

# Scripts must stay LF (they run in Linux containers / k8s).
*.sh text eol=lf

# Windows-only scripts stay CRLF.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Treat as binary (no EOL normalization, no diff noise).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
