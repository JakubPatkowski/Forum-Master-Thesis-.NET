# Base URL of the .NET backend (Forum.Api). The browser talks to it directly —
# there is no Next.js server proxy in between.
NEXT_PUBLIC_API_URL=http://localhost:5099

# WebSocket endpoint for the realtime change feed. Optional: when unset, it is
# derived from NEXT_PUBLIC_API_URL (http -> ws, https -> wss) + /api/realtime/ws.
# NEXT_PUBLIC_WS_URL=ws://localhost:5099/api/realtime/ws
