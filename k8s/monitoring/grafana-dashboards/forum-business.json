  {
   "id": 2,
   "type": "timeseries",
   "title": "Auth attempts by outcome",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (outcome) (rate(forum_auth_attempts_total[$__rate_interval])) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{outcome}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "cps",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 1,
    "w": 8,
    "h": 8
   },
   "description": "success | invalid_credentials | blocked \u2014 an invalid_credentials spike pairs with the 401 panel on Errors & Problems"
