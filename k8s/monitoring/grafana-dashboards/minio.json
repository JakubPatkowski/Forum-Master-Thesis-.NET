{
 "uid": "forum-minio",
 "title": "Forum / MinIO",
 "tags": [
  "forum",
  "phase-10c"
 ],
 "timezone": "browser",
 "schemaVersion": 39,
 "version": 1,
 "editable": true,
 "graphTooltip": 1,
 "refresh": "30s",
 "time": {
  "from": "now-30m",
  "to": "now"
 },
 "templating": {
  "list": []
 },
 "annotations": {
  "list": [
   {
    "builtIn": 1,
    "datasource": {
     "type": "grafana",
     "uid": "-- Grafana --"
    },
    "enable": true,
    "hide": true,
    "iconColor": "rgba(0, 211, 255, 1)",
    "name": "Annotations & Alerts",
    "type": "dashboard"
   }
  ]
 },
 "links": [
  {
   "type": "dashboards",
   "tags": [
    "forum"
   ],
   "asDropdown": true,
   "title": "Forum dashboards",
   "includeVars": false,
   "keepTime": true
  }
 ],
 "panels": [
  {
   "id": 1,
   "type": "row",
   "title": "Bucket (forum)",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 2,
   "type": "timeseries",
   "title": "Bucket size",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "minio_bucket_usage_total_bytes{bucket=\"forum\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "bytes"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "bytes",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 1,
    "w": 8,
    "h": 8
   },
   "description": "Watch it grow during the k6 upload scenario, then shrink as the orphan sweep runs"
  },
  {
   "id": 3,
   "type": "timeseries",
   "title": "Object count",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "minio_bucket_usage_object_total{bucket=\"forum\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "objects"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 8,
    "y": 1,
    "w": 8,
    "h": 8
   }
  },
  {
   "id": 4,
   "type": "stat",
   "title": "S3 errors (5m)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(increase(minio_s3_requests_errors_total[5m])) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "instant": true,
     "range": false
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    },
    "colorMode": "background",
    "graphMode": "none",
    "justifyMode": "auto"
   },
   "gridPos": {
    "x": 16,
    "y": 1,
    "w": 4,
    "h": 8
   }
  },
  {
   "id": 5,
   "type": "row",
   "title": "S3 traffic",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 9,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 6,
   "type": "timeseries",
   "title": "Request rate by API",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (api) (rate(minio_s3_requests_total[$__rate_interval]))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{api}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "reqps",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 10,
    "w": 12,
    "h": 8
   },
   "description": "PutObject = presigned uploads (ADR 0008: bytes bypass the backend), GetObject = downloads"
  },
  {
   "id": 7,
   "type": "timeseries",
   "title": "TTFB p95 by API",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "histogram_quantile(0.95, sum by (le, api) (rate(minio_s3_requests_ttfb_seconds_distribution[$__rate_interval])))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{api}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "s",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 12,
    "y": 10,
    "w": 12,
    "h": 8
   },
   "description": "minio_s3_requests_ttfb_seconds_distribution: le-labeled series without _bucket suffix (verified against RELEASE.2025-09-07)"
  }
 ]
}
