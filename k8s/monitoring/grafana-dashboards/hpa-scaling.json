{
 "uid": "forum-hpa",
 "title": "Forum / HPA Scaling",
 "tags": [
  "forum",
  "phase-10c"
 ],
 "timezone": "browser",
 "schemaVersion": 39,
 "version": 1,
 "editable": true,
 "graphTooltip": 1,
 "refresh": "30s",
 "time": {
  "from": "now-30m",
  "to": "now"
 },
 "templating": {
  "list": []
 },
 "annotations": {
  "list": [
   {
    "builtIn": 1,
    "datasource": {
     "type": "grafana",
     "uid": "-- Grafana --"
    },
    "enable": true,
    "hide": true,
    "iconColor": "rgba(0, 211, 255, 1)",
    "name": "Annotations & Alerts",
    "type": "dashboard"
   },
   {
    "name": "Scale events",
    "datasource": {
     "type": "prometheus",
     "uid": "prometheus"
    },
    "enable": true,
    "iconColor": "orange",
    "titleFormat": "HPA scaled",
    "expr": "changes(kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=\"backend\"}[1m]) > 0"
   }
  ]
 },
 "links": [
  {
   "type": "dashboards",
   "tags": [
    "forum"
   ],
   "asDropdown": true,
   "title": "Forum dashboards",
   "includeVars": false,
   "keepTime": true
  }
 ],
 "panels": [
  {
   "id": 1,
   "type": "row",
   "title": "Replicas (the thesis demo graph)",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 2,
   "type": "timeseries",
   "title": "Backend replicas: current / desired / max",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=\"backend\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "current"
    },
    {
     "refId": "B",
     "expr": "kube_horizontalpodautoscaler_status_desired_replicas{horizontalpodautoscaler=\"backend\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "desired"
    },
    {
     "refId": "C",
     "expr": "kube_horizontalpodautoscaler_spec_max_replicas{horizontalpodautoscaler=\"backend\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "max (spec)"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "min": 0
    },
    "overrides": [
     {
      "matcher": {
       "id": "byFrameRefID",
       "options": "C"
      },
      "properties": [
       {
        "id": "custom.lineStyle",
        "value": {
         "dash": [
          10,
          10
         ],
         "fill": "dash"
        }
       },
       {
        "id": "color",
        "value": {
         "fixedColor": "red",
         "mode": "fixed"
        }
       },
       {
        "id": "custom.fillOpacity",
        "value": 0
       }
      ]
     }
    ]
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 1,
    "w": 12,
    "h": 8
   },
   "description": "Orange annotations mark scale events"
  },
  {
   "id": 3,
   "type": "timeseries",
   "title": "The driving signal: CPU utilization vs 70% target",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"forum-dotnet\", pod=~\"backend-.*\", container=\"\"}[2m])) / sum(kube_pod_container_resource_requests{namespace=\"forum-dotnet\", resource=\"cpu\", pod=~\"backend-.*\"})",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "cpu / requests"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      },
      "thresholdsStyle": {
       "mode": "dashed+area"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 0.7
       }
      ]
     },
     "unit": "percentunit",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 12,
    "y": 1,
    "w": 12,
    "h": 8
   },
   "description": "HPA target: averageUtilization 70% of the 150m request. [2m] matches metrics-server cadence \u2014 do not narrow it."
  },
  {
   "id": 4,
   "type": "row",
   "title": "Per-pod resource small multiples",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 9,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 5,
   "type": "timeseries",
   "title": "Per-pod CPU (backend)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"forum-dotnet\", pod=~\"backend-.*\", container=\"\"}[2m]))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{pod}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 10,
    "w": 8,
    "h": 8
   },
   "description": "cores"
  },
  {
   "id": 6,
   "type": "timeseries",
   "title": "Per-pod memory (backend)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"forum-dotnet\", pod=~\"backend-.*\", container=\"\"})",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{pod}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "bytes",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 8,
    "y": 10,
    "w": 8,
    "h": 8
   }
  },
  {
   "id": 7,
   "type": "timeseries",
   "title": "Traffic driving the scale",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"backend\"}[$__rate_interval]))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "req/s"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "reqps",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 16,
    "y": 10,
    "w": 8,
    "h": 8
   }
  }
 ]
}
