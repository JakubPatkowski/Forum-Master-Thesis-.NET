{
 "uid": "forum-errors",
 "title": "Forum / Errors & Problems",
 "tags": [
  "forum",
  "phase-10c"
 ],
 "timezone": "browser",
 "schemaVersion": 39,
 "version": 1,
 "editable": true,
 "graphTooltip": 1,
 "refresh": "10s",
 "time": {
  "from": "now-30m",
  "to": "now"
 },
 "templating": {
  "list": []
 },
 "annotations": {
  "list": [
   {
    "builtIn": 1,
    "datasource": {
     "type": "grafana",
     "uid": "-- Grafana --"
    },
    "enable": true,
    "hide": true,
    "iconColor": "rgba(0, 211, 255, 1)",
    "name": "Annotations & Alerts",
    "type": "dashboard"
   }
  ]
 },
 "links": [
  {
   "type": "dashboards",
   "tags": [
    "forum"
   ],
   "asDropdown": true,
   "title": "Forum dashboards",
   "includeVars": false,
   "keepTime": true
  }
 ],
 "panels": [
  {
   "id": 1,
   "type": "row",
   "title": "Recent errors (Loki \u2014 OBSERVABILITY-CONTRACT.md \u00a71)",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 2,
   "type": "logs",
   "title": "Recent backend errors (Error + Fatal)",
   "datasource": {
    "type": "loki",
    "uid": "loki"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "{namespace=\"forum-dotnet\", app=\"backend\"} | json | _l=~\"Error|Fatal\" | line_format \"{{._m}}\"",
     "datasource": {
      "type": "loki",
      "uid": "loki"
     },
     "queryType": "range"
    }
   ],
   "options": {
    "showTime": true,
    "showLabels": false,
    "showCommonLabels": false,
    "wrapLogMessage": true,
    "prettifyLogMessage": false,
    "enableLogDetails": true,
    "dedupStrategy": "none",
    "sortOrder": "Descending"
   },
   "gridPos": {
    "x": 0,
    "y": 1,
    "w": 24,
    "h": 10
   },
   "description": "Click a line \u2192 Log details \u2192 TraceID derived field jumps to Tempo. @l is only present on non-Information lines (CLEF), so this is cheap."
  },
  {
   "id": 3,
   "type": "row",
   "title": "Unhandled errors & background loops",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 11,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 4,
   "type": "timeseries",
   "title": "Unhandled exceptions by category",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (category) (rate(forum_errors_unhandled_total[$__rate_interval])) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{category}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      },
      "thresholdsStyle": {
       "mode": "dashed+area"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 0.001
       }
      ]
     },
     "unit": "cps",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 12,
    "w": 12,
    "h": 8
   },
   "description": "Closed set: database|timeout|other. Client disconnects excluded at the source \u2014 ANY sustained rate is a defect."
  },
  {
   "id": 5,
   "type": "timeseries",
   "title": "Background loop tick age (the silently-dead-loop detector)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "max by (service) (forum_hosted_service_tick_age_seconds)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{service}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      },
      "thresholdsStyle": {
       "mode": "dashed+area"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 120
       }
      ]
     },
     "unit": "s",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 12,
    "y": 12,
    "w": 12,
    "h": 8
   },
   "description": "forum_hosted_service_tick_age_seconds \u2014 outbox relays/consumers/realtime tick every ~1s (alert >120s), orphan-sweep every 15min (alert >2700s). /health/ready CANNOT see a dead loop; this gauge is the only proof of life."
  },
  {
   "id": 6,
   "type": "row",
   "title": "Expected rejections (Result pattern) \u2014 two very different signals",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 20,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 7,
   "type": "timeseries",
   "title": "Security signal: 401/403 rate",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (errorType) (rate(forum_api_rejections_total{errorType=~\"Unauthorized|Forbidden\"}[$__rate_interval])) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{errorType}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      },
      "thresholdsStyle": {
       "mode": "dashed+area"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 1
       }
      ]
     },
     "unit": "cps",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 21,
    "w": 12,
    "h": 8
   },
   "description": "A spike here is ATTACK-shaped (or a broken token-refresh loop). Compare with auth attempts on Forum Business."
  },
  {
   "id": 8,
   "type": "timeseries",
   "title": "Contract signal: validation & client-error rate",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (errorType) (rate(forum_api_rejections_total{errorType!~\"Unauthorized|Forbidden\"}[$__rate_interval])) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{errorType}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "cps",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 12,
    "y": 21,
    "w": 12,
    "h": 8
   },
   "description": "A 422 (Validation/BadRequest) spike is FRONTEND-BUG-shaped: the SPA is sending requests the API rejects. NotFound/Conflict are normal in small numbers."
  },
  {
   "id": 9,
   "type": "row",
   "title": "HTTP failures & messaging poison",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 29,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 10,
   "type": "timeseries",
   "title": "5xx rate",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"backend\", http_response_status_code=~\"5..\"}[$__rate_interval])) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "5xx"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      },
      "thresholdsStyle": {
       "mode": "dashed+area"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 0.1
       }
      ]
     },
     "unit": "reqps",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 30,
    "w": 8,
    "h": 8
   }
  },
  {
   "id": 11,
   "type": "table",
   "title": "Failing routes (4xx/5xx, last 15m)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (http_route, http_response_status_code) (increase(http_server_request_duration_seconds_count{job=\"backend\", http_response_status_code=~\"4..|5..\"}[15m])) > 0",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "instant": true,
     "range": false,
     "format": "table"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "align": "auto",
      "cellOptions": {
       "type": "auto"
      }
     }
    },
    "overrides": []
   },
   "transformations": [
    {
     "id": "organize",
     "options": {
      "excludeByName": {
       "Time": true
      }
     }
    }
   ],
   "options": {
    "showHeader": true,
    "sortBy": [
     {
      "displayName": "Value",
      "desc": true
     }
    ]
   },
   "gridPos": {
    "x": 8,
    "y": 30,
    "w": 8,
    "h": 8
   },
   "description": "Per-endpoint failure counts \u2014 which route is producing the errors above"
  },
  {
   "id": 12,
   "type": "timeseries",
   "title": "Poison-queue depth trend",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rabbitmq_queue_messages_ready{queue=~\".*\\\\.poison\"}) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "poison total"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      },
      "thresholdsStyle": {
       "mode": "dashed+area"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 1
       }
      ]
     },
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 16,
    "y": 30,
    "w": 8,
    "h": 8
   },
   "description": "Trend, not just current depth: WHEN messages were parked matters during a benchmark run"
  }
 ]
}
