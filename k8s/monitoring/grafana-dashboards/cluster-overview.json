  {
   "id": 7,
   "type": "stat",
   "title": "Stalest fast loop",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "max(forum_hosted_service_tick_age_seconds{service!=\"orphan-sweep\"})",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "instant": true,
     "range": false
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 120
       }
      ]
     },
     "unit": "s"
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    },
    "colorMode": "background",
    "graphMode": "none",
    "justifyMode": "auto"
   },
   "gridPos": {
    "x": 20,
    "y": 1,
    "w": 4,
    "h": 4
   },
   "description": "Relays/consumers/realtime tick ~1s; sweeper excluded (its normal tick age reaches 900s) \u2014 per-loop view on Errors & Problems"
  },
  {
