  {
   "id": 9,
   "type": "timeseries",
   "title": "Node CPU %",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval]))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "cpu busy"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      },
      "thresholdsStyle": {
       "mode": "dashed+area"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 0.9
       }
      ]
     },
     "unit": "percentunit",
     "min": 0,
     "max": 1
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 6,
    "w": 12,
    "h": 8
   }
  },
