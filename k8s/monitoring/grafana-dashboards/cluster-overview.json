   "description": "Anything >0: investigate before trusting benchmark data"
  },
  {
   "id": 6,
   "type": "stat",
   "title": "Firing alerts",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "count(ALERTS{alertstate=\"firing\", alertname!=\"Watchdog\"}) or vector(0)",
