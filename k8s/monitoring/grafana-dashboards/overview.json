   "id": 14,
   "type": "gauge",
   "title": "Backend replicas (of max)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=\"backend\"} / kube_horizontalpodautoscaler_spec_max_replicas{horizontalpodautoscaler=\"backend\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "instant": true,
     "range": false
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percentunit",
     "min": 0,
     "max": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "blue",
        "value": 0.99
       }
      ]
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
