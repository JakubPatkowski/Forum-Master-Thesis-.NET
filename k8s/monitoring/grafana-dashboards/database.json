   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(pg_stat_database_xact_commit{datname=~\"forum_net.*\"}[$__rate_interval]))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
