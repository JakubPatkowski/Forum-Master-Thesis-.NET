  {
   "id": 6,
   "type": "timeseries",
   "title": "Row throughput / s",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(pg_stat_database_tup_fetched{datname=~\"forum_net.*\"}[$__rate_interval]))",
