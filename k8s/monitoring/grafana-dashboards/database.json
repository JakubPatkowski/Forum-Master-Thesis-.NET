     "legendFormat": "commit"
    },
    {
     "refId": "B",
     "expr": "sum(rate(pg_stat_database_xact_rollback{datname=~\"forum_net.*\"}[$__rate_interval]))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "rollback"
    }
