   "gridPos": {
    "x": 12,
    "y": 1,
    "w": 12,
    "h": 8
   },
   "description": "idle-in-transaction growth = a leaked transaction scope"
  },
  {
   "id": 4,
   "type": "row",
   "title": "Throughput",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 9,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
