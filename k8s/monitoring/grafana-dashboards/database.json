   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "ops",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
