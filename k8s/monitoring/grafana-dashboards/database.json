  {
   "id": 7,
   "type": "timeseries",
   "title": "Cache hit ratio (5m)",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(pg_stat_database_blks_hit{datname=~\"forum_net.*\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname=~\"forum_net.*\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=~\"forum_net.*\"}[5m])))",
