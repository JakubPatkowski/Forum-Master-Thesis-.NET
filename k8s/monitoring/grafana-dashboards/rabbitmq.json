  "to": "now"
 },
 "templating": {
  "list": []
 },
 "annotations": {
  "list": [
   {
    "builtIn": 1,
    "datasource": {
     "type": "grafana",
     "uid": "-- Grafana --"
    },
    "enable": true,
    "hide": true,
    "iconColor": "rgba(0, 211, 255, 1)",
    "name": "Annotations & Alerts",
    "type": "dashboard"
   }
  ]
 },
 "links": [
  {
   "type": "dashboards",
   "tags": [
    "forum"
   ],
   "asDropdown": true,
   "title": "Forum dashboards",
   "includeVars": false,
   "keepTime": true
  }
 ],
 "panels": [
  {
   "id": 1,
   "type": "row",
   "title": "Queues (per-object metrics \u2014 enabled in the 10b configmap)",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 2,
   "type": "timeseries",
   "title": "Ready messages by queue",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "rabbitmq_queue_messages_ready{queue!~\"amq\\\\.gen.*\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{queue}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 1,
    "w": 10,
    "h": 8
   },
   "description": "<module>.events = work; .retry = delayed redelivery; .poison = parked failures"
  },
  {
   "id": 3,
   "type": "timeseries",
   "title": "Unacked messages by queue",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "rabbitmq_queue_messages_unacked{queue!~\"amq\\\\.gen.*\"}",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "{{queue}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 10,
    "y": 1,
    "w": 10,
    "h": 8
   },
   "description": "Sustained growth = a consumer holding deliveries without acking (stuck handler)"
  },
  {
   "id": 4,
   "type": "stat",
   "title": "Poison depth NOW",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rabbitmq_queue_messages_ready{queue=~\".*\\\\.poison\"}) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     }
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "red",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    },
    "colorMode": "background",
    "graphMode": "area",
    "justifyMode": "auto"
   },
   "gridPos": {
    "x": 20,
    "y": 1,
    "w": 4,
    "h": 8
   },
   "description": "The Phase 6 design's alarm bell \u2014 trend view on Errors & Problems"
  },
  {
   "id": 5,
   "type": "row",
   "title": "Flow",
   "collapsed": false,
   "gridPos": {
    "x": 0,
    "y": 9,
    "w": 24,
    "h": 1
   },
   "panels": []
  },
  {
   "id": 6,
   "type": "timeseries",
   "title": "Publish / deliver / ack rates",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(rabbitmq_global_messages_received_total[$__rate_interval])) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "received (publish)"
    },
    {
     "refId": "B",
     "expr": "(sum(rate(rabbitmq_global_messages_delivered_consume_auto_ack_total[$__rate_interval])) or vector(0)) + (sum(rate(rabbitmq_global_messages_delivered_consume_manual_ack_total[$__rate_interval])) or vector(0))",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "delivered"
    },
    {
     "refId": "C",
     "expr": "sum(rate(rabbitmq_global_messages_acknowledged_total[$__rate_interval])) or vector(0)",
     "datasource": {
      "type": "prometheus",
      "uid": "prometheus"
     },
     "legendFormat": "acknowledged"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "color": {
      "mode": "palette-classic"
     },
     "custom": {
      "drawStyle": "line",
      "lineInterpolation": "linear",
      "lineWidth": 1,
      "fillOpacity": 8,
      "showPoints": "never",
      "spanNulls": true,
      "stacking": {
       "mode": "none"
      }
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "unit": "mps",
     "min": 0
    },
    "overrides": []
   },
   "options": {
    "legend": {
     "displayMode": "list",
     "placement": "bottom",
     "showLegend": true,
     "calcs": []
    },
    "tooltip": {
     "mode": "multi",
     "sort": "desc"
    }
   },
   "gridPos": {
    "x": 0,
    "y": 10,
    "w": 8,
    "h": 8
   }
  },
