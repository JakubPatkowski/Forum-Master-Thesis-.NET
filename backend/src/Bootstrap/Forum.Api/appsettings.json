{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Npgsql.Command": "Warning"
      }
    },
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": { "Forum": "Host=localhost;Port=5432;Database=forum_net;Username=forum;Password=__SET_VIA_SECRET__" },
  "Jwt": { "Issuer": "forum-dotnet", "Audience": "forum-dotnet", "AccessTokenMinutes": 15, "RefreshTokenDays": 14 },
  "RabbitMq": { "Host": "localhost", "Port": 5672, "Username": "guest", "Password": "guest" },
  "Messaging": {
    "PollIntervalMilliseconds": 5000,
    "BatchSize": 50,
    "MaxPublishBackoffMilliseconds": 30000,
    "RetryDelayMilliseconds": 5000,
    "MaxDeliveryAttempts": 5,
    "Prefetch": 10
  },
  "Storage": { "Endpoint": "localhost:9000", "Bucket": "forum", "AccessKey": "", "SecretKey": "", "UseSsl": false },
  "Files": {
    "UploadUrlTtlMinutes": 10,
    "DownloadUrlTtlMinutes": 15,
    "MaxSizeBytes": 5242880,
    "AllowedContentTypes": [ "image/png", "image/jpeg", "image/gif", "image/webp" ],
    "ProbeBytes": 131072,
    "PendingGraceMinutes": 60,
    "UnattachedGraceMinutes": 1440,
    "SweepIntervalMinutes": 15,
    "SweepBatchSize": 100,
    "MaxAttachmentsPerTarget": 10
  },
  "Realtime": { "TicketTtlSeconds": 30, "MaxSubscriptionsPerConnection": 64 },
  "Otlp": { "Endpoint": "http://localhost:4317" },
  "ForwardedHeaders": { "KnownNetworks": [] },
  "Cors": { "AllowedOrigins": [ "http://localhost:5173", "http://localhost:3000" ] },
  "AllowedHosts": "*"
}
